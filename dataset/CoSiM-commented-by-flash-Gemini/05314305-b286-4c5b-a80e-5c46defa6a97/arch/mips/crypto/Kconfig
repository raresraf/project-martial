#
# @brief Kconfig file for MIPS architecture-specific cryptographic algorithms.
# This file defines the kernel configuration options for accelerated cryptographic
# algorithms, such as MD5, SHA-1, and SHA-512, specifically optimized for the
# Cavium OCTEON processors within the MIPS architecture. It enables selective
# inclusion of these algorithms based on hardware support.
#
# Domain: Linux Kernel, Kconfig, MIPS Architecture, Cryptography.
#
# SPDX-License-Identifier: GPL-2.0

menu "Accelerated Cryptographic Algorithms for CPU (mips)"
# Block Logic: Configuration entry for MD5 cryptographic algorithm on OCTEON.
# Enables the selection of MD5 message digest algorithm, dependent on the
# presence of Cavium OCTEON CPU. It automatically selects the generic
# CRYPTO_MD5 and CRYPTO_HASH options.
config CRYPTO_MD5_OCTEON
	tristate "Digests: MD5 (OCTEON)"
	depends on CPU_CAVIUM_OCTEON
	select CRYPTO_MD5
	select CRYPTO_HASH
	help
	  MD5 message digest algorithm (RFC1321)

	  Architecture: mips OCTEON using crypto instructions, when available

# Block Logic: Configuration entry for SHA-1 cryptographic algorithm on OCTEON.
# Enables the selection of SHA-1 secure hash algorithm, dependent on the
# presence of Cavium OCTEON CPU. It automatically selects the generic
# CRYPTO_SHA1 and CRYPTO_HASH options.
config CRYPTO_SHA1_OCTEON
	tristate "Hash functions: SHA-1 (OCTEON)"
	depends on CPU_CAVIUM_OCTEON
	select CRYPTO_SHA1
	select CRYPTO_HASH
	help
	  SHA-1 secure hash algorithm (FIPS 180)

	  Architecture: mips OCTEON

# Block Logic: Configuration entry for SHA-384 and SHA-512 algorithms on OCTEON.
# Enables the selection of SHA-384 and SHA-512 secure hash algorithms,
# dependent on the presence of Cavium OCTEON CPU. It automatically selects
# the generic CRYPTO_SHA512 and CRYPTO_HASH options.
config CRYPTO_SHA512_OCTEON
	tristate "Hash functions: SHA-384 and SHA-512 (OCTEON)"
	depends on CPU_CAVIUM_OCTEON
	select CRYPTO_SHA512
	select CRYPTO_HASH
	help
	  SHA-384 and SHA-512 secure hash algorithms (FIPS 180)

	  Architecture: mips OCTEON using crypto instructions, when available

endmenu
